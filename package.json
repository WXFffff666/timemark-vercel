{
  "name": "timemark-vercel",
  "version": "2.11.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "devDependencies": {
    "hono": "^4.0.0",
    "@vercel/functions": "^1.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.7.0"
  },
  "scripts": {
    "install:deps": "pnpm install --config.blockExoticSubdeps=false",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "build:shared": "pnpm --filter @timemark/shared build",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "build:vercel-api": "node scripts/build-vercel-api.mjs",
    "build": "pnpm build:shared && pnpm build:backend && pnpm build:frontend && pnpm build:vercel-api"
  }
}
