# TimeMark Vercel — Environment Variables
# Copy to .env for local dev, or set in Vercel Dashboard → Settings → Environment Variables

# === Required ===
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=your-64-char-hex-secret
MASTER_KEY=your-64-char-hex-aes-key
CRON_SECRET=your-random-cron-secret

# === Recommended ===
NODEJS_HELPERS=0
CORS_ORIGIN=https://your-app.vercel.app
TZ=Asia/Shanghai

# === Optional (login bot protection) ===
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# See docs/TURNSTILE_SETUP.md — create widget for timemark.the37777777.top

# === Optional ===
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=TimeMark@2026
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
LOG_LEVEL=info
LOG_QUERIES=false

# Generate secrets (PowerShell):
# -join ((1..64) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
