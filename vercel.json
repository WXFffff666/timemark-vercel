{
  "framework": null,
  "installCommand": "pnpm install --config.blockExoticSubdeps=false",
  "buildCommand": "pnpm build",
  "outputDirectory": "frontend/dist",
  "crons": [
    {
      "path": "/api/cron/daily-maintenance",
      "schedule": "0 2 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/*.ts": {
      "maxDuration": 30
    }
  }
}
