{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/daily-maintenance",
      "schedule": "0 2 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "services": {
    "timemark": {
      "root": ".",
      "framework": "vite",
      "installCommand": "pnpm install --config.blockExoticSubdeps=false",
      "buildCommand": "pnpm build",
      "outputDirectory": "frontend/dist",
      "functions": {
        "api/*.ts": {
          "maxDuration": 30
        }
      }
    }
  }
}
